# Web
WATCHMYLAN_HOST=192.168.1.10
APP_PORT=8088
HTTPS_PORT=8443

# Scanner
SCAN_INTERVAL_SECONDS=120
OFFLINE_AFTER_MISSES=3
ARP_TIMEOUT_SECONDS=2
ARP_RETRIES=1
ARP_PASSES=3
INCLUDE_KERNEL_NEIGHBORS=true
ENABLE_PING_SWEEP=true
PING_TIMEOUT_SECONDS=1
PING_WORKERS=128

# Telegram: telegram://BOT_TOKEN@telegram?channels=CHAT_ID
TELEGRAM_URL=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=
SMTP_TLS=true
